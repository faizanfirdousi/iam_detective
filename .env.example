# ─── Generic fallback (used if case-specific vars are not set) ─────────────────
DO_AGENT_ENDPOINT=https://your-default-agent.agents.do-ai.run
DO_AGENT_ACCESS_KEY=your-default-access-key

# ─── Zodiac Killer Agent ───────────────────────────────────────────────────────
DO_AGENT_ZODIAC_ENDPOINT=https://your-zodiac-agent.agents.do-ai.run
DO_AGENT_ZODIAC_ACCESS_KEY=your-zodiac-access-key

# ─── Aarushi Talwar Agent ──────────────────────────────────────────────────────
DO_AGENT_AARUSHI_ENDPOINT=https://your-aarushi-agent.agents.do-ai.run
DO_AGENT_AARUSHI_ACCESS_KEY=your-aarushi-access-key

# ─── OJ Simpson Agent ─────────────────────────────────────────────────────────
DO_AGENT_OJ_ENDPOINT=https://your-oj-agent.agents.do-ai.run
DO_AGENT_OJ_ACCESS_KEY=your-oj-access-key

# ─── CORS (comma-separated list of allowed frontend origins) ──────────────────
CORS_ORIGINS=http://localhost:3000
